APP_ENV=dev
DEBUG=true
TZ=Asia/Shanghai

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=jrtt_tool

# 爬虫任务执行间隔（秒），例如 120 表示每 2 分钟抓取一次
CRAWL_INTERVAL_SECONDS=120
# 过期数据清理任务执行间隔（分钟），会删除超过 24 小时的新闻
CLEANUP_INTERVAL_MINUTES=30
# 本地调试可关闭爬虫定时任务（false 表示不执行抓取 job）
CRAWL_JOB_ENABLED=true
# 本地调试可关闭清理定时任务
CLEANUP_JOB_ENABLED=true
# 每轮抓取的目标文章数量上限（实际入库数量会因过滤而更少）
CRAWL_TARGET_COUNT=20
# 推荐页向下滚动加载轮次（值越大候选越多，但耗时更长）
CRAWL_LIST_SCROLL_ROUNDS=6
# 详情抓取并行线程数（单进程多线程；建议 2~4）
CRAWL_DETAIL_WORKERS=3
# 仅保留最近多少小时内的新闻
CRAWL_MAX_HOURS=24
# 作者粉丝数上限（仅保留粉丝数小于该值的文章）
CRAWL_MAX_FANS=10000
# 作者名称关键词黑名单（命中即过滤，英文逗号分隔）
CRAWL_BLOCK_AUTHOR_KEYWORDS=政府,检察院,法院,公安,交警,消防,税务,纪委,共青团,网信办,发布,融媒体中心
# 可选：指定本地 chromedriver.exe 绝对路径（内网/离线环境建议设置）
CHROMEDRIVER_PATH=
# 可选：指定 Chrome/Chromium 浏览器可执行文件路径（Docker Linux 推荐配置）
CHROME_BINARY_PATH=
# Selenium 是否无头模式：true 后台运行，false 可见浏览器窗口（便于调试）
CRAWL_HEADLESS=true
TOUTIAO_URL=https://www.toutiao.com/

DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
