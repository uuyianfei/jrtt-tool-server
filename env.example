APP_ENV=dev
DEBUG=true
TZ=Asia/Shanghai

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=jrtt_tool

# 爬虫任务执行间隔（秒），例如 120 表示每 2 分钟抓取一次
CRAWL_INTERVAL_SECONDS=120
# 过期数据清理任务执行间隔（分钟），会删除超过 24 小时的新闻
CLEANUP_INTERVAL_MINUTES=30
# claim 表清理保留时长（小时），会删除过期超过该时长的 fast_crawl_claims/author_fans_claims
CLAIM_CLEANUP_RETENTION_HOURS=24
# 本地调试可关闭爬虫定时任务（false 表示不执行抓取 job）
CRAWL_JOB_ENABLED=true
# 本地调试可关闭清理定时任务
CLEANUP_JOB_ENABLED=true
# 每轮抓取的目标文章数量上限（实际入库数量会因过滤而更少）
CRAWL_TARGET_COUNT=120
# 推荐页向下滚动加载轮次（值越大候选越多，但耗时更长）
CRAWL_LIST_SCROLL_ROUNDS=10
# 推荐页首次打开后等待秒数（有头模式建议 0.8~1.5）
CRAWL_LIST_INITIAL_WAIT_SECONDS=1.0
# 推荐页 refresh 后等待秒数
CRAWL_LIST_REFRESH_WAIT_SECONDS=1.0
# 每次滚动后的等待秒数
CRAWL_LIST_SCROLL_WAIT_SECONDS=0.9
# 连续多少轮无新增卡片则提前停止滚动（0 表示关闭提前停止）
CRAWL_LIST_NO_GROWTH_EARLY_STOP_ROUNDS=2
# 详情抓取并行线程数（单进程多线程；建议 2~4）
CRAWL_DETAIL_WORKERS=2
# 仅保留最近多少小时内的新闻
CRAWL_MAX_HOURS=24
# 第一条线执行间隔（秒）
AUTHOR_COLLECT_INTERVAL_SECONDS=600
# 第二条线执行间隔（秒）
AUTHOR_CRAWL_INTERVAL_SECONDS=600
# 第二条线是否常驻循环抓取（true=无固定周期，持续检查可抓作者）
AUTHOR_ARTICLES_CONTINUOUS_ENABLED=true
# 常驻循环在“无可抓作者”时的休眠秒数
AUTHOR_ARTICLES_IDLE_SLEEP_SECONDS=30
# 第一条线每轮从推荐页提取作者候选上限
AUTHOR_COLLECT_TARGET_COUNT=120
# 第一条线作者粉丝探测并发数（有头模式建议 2~4）
AUTHOR_COLLECT_FANS_WORKERS=1
# 第二条线每轮作者池处理数量
AUTHOR_CRAWL_BATCH_SIZE=10
# 第二条线每个作者每轮抓取文章上限
AUTHOR_PER_AUTHOR_TARGET_COUNT=12
# 单个作者最短重抓间隔（小时），例如 1 表示同一作者 1 小时内不会被重复抓取
AUTHOR_RECRAWL_INTERVAL_HOURS=1
# 当作者页首轮未解析到阅读量时，是否回退为“按文章单独补查阅读量”（会明显变慢）
AUTHOR_READ_COUNT_FALLBACK_ENABLED=false
# 作者抓文任务是否在单次执行中持续处理直到“到期作者”全部抓完
AUTHOR_ARTICLES_RUN_UNTIL_EXHAUSTED=true
# 作者采集到“新作者”后是否立即触发一次作者抓文
AUTHOR_TRIGGER_ARTICLES_ON_COLLECT=true
# 作者粉丝数上限（仅保留粉丝数小于该值的文章）
CRAWL_MAX_FANS=10000
# 作者名称关键词黑名单（命中即过滤，英文逗号分隔）
CRAWL_BLOCK_AUTHOR_KEYWORDS=政府,检察院,法院,公安,交警,消防,税务,纪委,共青团,网信办,发布,融媒体中心
# 可选：指定本地 chromedriver.exe 绝对路径（内网/离线环境建议设置）
CHROMEDRIVER_PATH=
# 可选：指定 Chrome/Chromium 浏览器可执行文件路径（Docker Linux 推荐配置）
CHROME_BINARY_PATH=
# 可选：自定义 UA（默认留空使用浏览器真实 UA，通常更不易被风控）
CRAWL_USER_AGENT=
# Selenium 是否无头模式：true 后台运行，false 可见浏览器窗口（便于调试）
CRAWL_HEADLESS=true
# 详情页正文等待超时（秒）
DETAIL_PAGE_READY_TIMEOUT_SECONDS=12
# 空白详情页恢复最大轮次（每轮含 refresh/home-jump/重建 driver）
BLANK_PAGE_RECOVERY_MAX_ROUNDS=2
TOUTIAO_URL=https://www.toutiao.com/

DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# --- 高速 HTTP 爬虫（无需 Selenium） ---
# 是否启用高速爬虫
FAST_CRAWL_ENABLED=false
# 多机器分片：固定两台时 shard_count=2，机器A: shard_index=0，机器B: shard_index=1
# gid 分片规则：sha256(gid) % shard_count
# 注意：当 FAST_CRAWL_CLAIM_ENABLED=true 时，为了“不漏写”，会跳过这套强分片过滤。
FAST_CRAWL_SHARD_COUNT=2
FAST_CRAWL_SHARD_INDEX=0
# 每轮爬取间隔（秒），120 = 每 2 分钟一轮
FAST_CRAWL_INTERVAL_SECONDS=120
# 爬取的频道列表（逗号分隔），频道越多候选越多
FAST_CRAWL_CHANNELS=__all__,news_hot,news_tech,news_finance,news_entertainment,news_sports,news_society,news_car,news_health,news_military,news_world,news_travel,news_history
# 详情 API 并发请求数
FAST_CRAWL_CONCURRENCY=10
# 仅保留最近多少小时内的新闻
FAST_CRAWL_MAX_HOURS=24
# 每个频道最大翻页数（50 页约覆盖 24 小时）
FAST_CRAWL_MAX_PAGES_PER_CHANNEL=50
# 请求间隔防反爬（秒）
FAST_CRAWL_REQUEST_DELAY=0.3
# 启动抖动（秒）：多实例错峰启动，减少瞬时突发
FAST_CRAWL_STARTUP_JITTER_SECONDS=20
# 循环抖动（秒）：每轮 interval 额外随机等待 0~N 秒
FAST_CRAWL_LOOP_JITTER_SECONDS=15
# 正文最小字数（低于此值的文章跳过）
FAST_CRAWL_MIN_CONTENT_LENGTH=80
# 作者粉丝数上限过滤（0 表示不限制）
FAST_CRAWL_MAX_FANS=0

# --- 高速 HTTP 爬虫 distributed claim（保证尽量不漏） ---
# 开启后：会忽略 FAST_CRAWL_SHARD_COUNT/INDEX 的强分片过滤；
# 每个 gid 在拉取 info/写入前会先抢占 lease，抢到的那台才处理。
FAST_CRAWL_CLAIM_ENABLED=true
# lease 时长（秒）：覆盖“fetch info + upsert articles”的典型耗时窗口（默认 900=15 分钟）
FAST_CRAWL_CLAIM_LEASE_SECONDS=900

# --- db.create_all 并发互斥（避免 MySQL 1684 并发 DDL）---
DB_CREATE_ALL_LOCK_ENABLED=true
DB_CREATE_ALL_LOCK_NAME=jrtt_db_create_all
DB_CREATE_ALL_LOCK_TIMEOUT_SECONDS=20
DB_CREATE_ALL_LOCK_MAX_TRIES=6
DB_CREATE_ALL_LOCK_SLEEP_SECONDS=2.0

# --- Reconcile pending "author followers" distributed claim ---
# Prevent multiple reconcile workers from updating the same `author_sources` row concurrently.
AUTHOR_FANS_CLAIM_ENABLED=true
# lease time (seconds): should cover "claim + fetch fans + update followers" typical window
AUTHOR_FANS_CLAIM_LEASE_SECONDS=240
